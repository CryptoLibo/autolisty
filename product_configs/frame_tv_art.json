{
  "product_name": "Frame TV Art",
  "product_type": "digital",

  "title_rules": {
    "capitalization": "title_case",

    "mandatory_terms": [
      "Frame TV Art",
      "(Digital Download)"
    ],

    "allow_variations": [
      "Frame TV Art",
      "Samsung Frame TV Art"
    ],

    "structure": [
      "STYLE",
      "SUBJECT",
      "SECOND_SUBJECT",
      "PRODUCT",
      ",",
      "DECOR_CONTEXT",
      "(Digital Download)"
    ],

    "word_rules": {
      "min_words": 13,
      "max_words": 15,
      "avoid_word_repetition": true
    },

    "seo_priorities": {
      "lead_with_searchable_language": true,
      "prefer_concrete_subjects_over_generic_adjectives": true,
      "require_semantic_coherence": true,
      "decor_context_must_support_the_art": true
    }
  },

  "analysis_rules": {
    "source_inputs": [
      "design_image",
      "midjourney_prompt"
    ],

    "required_outputs": [
      "primary_subject",
      "secondary_subject",
      "style",
      "decor_context",
      "mood",
      "color_palette",
      "search_intent"
    ],

    "prompt_handling": {
      "use_prompt_to_clarify_visual_intent": true,
      "do_not_copy_midjourney_syntax_into_seo": true,
      "prefer_etsy_search_language_over_prompt_jargon": true
    }
  },

  "tag_rules": {
    "max_tags": 13,
    "max_characters": 20,

    "semantic_distribution": {
      "product_type": 3,
      "style": 3,
      "subject": 3,
      "decor_context": 2,
      "digital_format": 2
    },

    "quality_rules": {
      "avoid_title_duplication": true,
      "avoid_near_duplicate_roots": true,
      "prefer_searchable_phrases": true
    }
  },

  "description_rules": {
    "template_file": "frame_tv_description.txt",

    "keyword_slots": 5,

    "roles": {
      "KEYWORD_1": "main_search_phrase",
      "KEYWORD_2": "artwork_phrase",
      "KEYWORD_3": "style_phrase",
      "KEYWORD_4": "decor_intent",
      "KEYWORD_5": "digital_art_phrase"
    },

    "keyword_rules": {
      "min_words": 2,
      "max_words": 4,
      "main_phrase_can_be_long_tail": true,
      "avoid_generic_keywords": true,
      "fit_template_naturally": true,
      "require_distinct_roles": true
    }
  },

  "image_rules": {
    "analysis": "visual_per_image",

    "alt_text": {
      "min_characters": 200,
      "max_characters": 250,

      "structure": [
        "visual_description",
        "art_style",
        "product_keyword",
        "optional_decor_context"
      ],

      "keyword_integration": "natural_and_selective",

      "image_types": [
        "mockup",
        "closeup",
        "informational",
        "promotional"
      ]
    }
  }
}
