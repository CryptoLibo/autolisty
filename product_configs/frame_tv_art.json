{
  "product_name": "Frame TV Art",
  "product_type": "digital",

  "title_rules": {
    "capitalization": "title_case",

    "mandatory_terms": [
      "Frame TV Art",
      "(Digital Download)"
    ],

    "allow_variations": [
      "Frame TV Art",
      "Samsung Frame TV Art"
    ],

    "structure": [
      "STYLE",
      "SUBJECT",
      "SECOND_SUBJECT",
      "PRODUCT",
      ",",
      "DECOR_CONTEXT",
      "(Digital Download)"
    ],

    "word_rules": {
      "min_words": 13,
      "max_words": 15,
      "avoid_word_repetition": true
    }
  },

  "tag_rules": {
    "max_tags": 13,
    "max_characters": 20,

    "semantic_distribution": {
      "product_type": 3,
      "style": 3,
      "subject": 3,
      "decor_context": 2,
      "digital_format": 2
    }
  },

  "description_rules": {
    "template_file": "frame_tv_description.txt",

    "keyword_slots": 5,

    "roles": {
      "KEYWORD_1": "main_search_phrase",
      "KEYWORD_2": "artwork_phrase",
      "KEYWORD_3": "style_phrase",
      "KEYWORD_4": "decor_intent",
      "KEYWORD_5": "digital_art_phrase"
    }
  },

  "image_rules": {
    "analysis": "visual_per_image",

    "alt_text": {
      "min_characters": 200,
      "max_characters": 250,

      "structure": [
        "visual_description",
        "art_style",
        "product_keyword",
        "optional_decor_context"
      ],

      "image_types": [
        "mockup",
        "closeup",
        "informational",
        "promotional"
      ]
    }
  }
}